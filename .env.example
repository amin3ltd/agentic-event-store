# =============================================================================
# Agentic Event Store - Environment Variables Template
# Copy this to .env and configure for your environment
# =============================================================================

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=apex_ledger
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30

# Event Store
EVENT_STORE_SNAPSHOT_INTERVAL=100
EVENT_STORE_MAX_STREAM_LOAD=1000
EVENT_STORE_OUTBOX_POLL_MS=100

# Projection Daemon
PROJECTION_POLL_MS=100
PROJECTION_BATCH_SIZE=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Health Check
HEALTH_ENABLED=true
HEALTH_PORT=8080

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8765
SERVER_WORKERS=4
